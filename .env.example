# URL do banco de dados principal (PostgreSQL/Supabase)
DATABASE_URL="postgresql://user:password@host:port/dbname"

# Segredo para assinatura de Tokens JWT. Gere uma string longa e aleatória (ex: `openssl rand -hex 32`)
JWT_SECRET="sua_chave_jwt_super_secreta_aqui"

# Domínios permitidos para acessar a API (CORS) - Separados por vírgula
ALLOWED_ORIGINS="https://seu-saas.com,http://localhost:3000"

# (Apenas Seeding Inicial) Senha do Super Admin. Altere no banco de dados assim que rodar a primeira vez!
SUPERADMIN_SEED_PASSWORD="sua_senha_super_forte_aqui_@2026"

# ==========================================
# INTEGRAÇÕES (FASES 1 a 6)
# ==========================================

# E-mail (Resend)
RESEND_API_KEY="re_..."
EMAIL_FROM="onboarding@seu-saas.com"

# IA de Remoção de Fundo (Se a API for externa)
AI_REMOVE_BG_API_URL="https://api.remove.bg/v1.0/removebg"
AI_API_KEY="sua_api_key_aqui"

# Cache & Filas (Redis / Celery)
REDIS_URL="redis://localhost:6379/0"

# Storage de Assets (AWS S3 ou R2)
S3_BUCKET="meu-bucket"
S3_ACCESS_KEY="minha_chave"
S3_SECRET_KEY="meu_segredo"
